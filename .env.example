# Application
APP_NAME=OnCall Mind
DEBUG=True
HOST=0.0.0.0
PORT=9900

# DashScope
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000
MILVUS_NPROBE=32

# RAG
RAG_TOP_K=3
RAG_MODEL=qwen-max
RAG_MODE=basic

# Enhanced RAG
QUERY_PREPROCESSOR_TYPE=none
RERANKER_TYPE=cross_encoder
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=3
RERANK_COARSE_TOP_K=10
RAG_DIVERSIFY_BY_FILE=false
RAG_DIVERSIFY_CANDIDATE_MULTIPLIER=3

# LLM
LLM_TEMPERATURE=0.0
LLM_CHAT_TEMPERATURE=0.7
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_FALLBACK_MODEL=qwen-plus

# Evaluation judge. Leave empty to reuse DashScope settings.
EVAL_JUDGE_MODEL=qwen3.5-plus
EVAL_JUDGE_TEMPERATURE=0.0
EVAL_JUDGE_API_BASE=
EVAL_JUDGE_API_KEY=

# Chunking
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# MCP
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# Redis
REDIS_URL=redis://localhost:6379

# Context trimming
CONTEXT_MAX_TOKENS=8000
CONTEXT_TRIMMING_STRATEGY=token_count
