# Copy this file to .env.docker and fill in real secrets locally.

APP_NAME=OnCall Mind
DEBUG=False
HOST=0.0.0.0
PORT=9900

DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_BATCH_SIZE=10

MILVUS_HOST=standalone
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000
MILVUS_NPROBE=32

RAG_TOP_K=3
RAG_MODEL=qwen-max
RAG_MODE=basic

QUERY_PREPROCESSOR_TYPE=none
RERANKER_TYPE=cross_encoder
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=3
RERANK_COARSE_TOP_K=10
RAG_DIVERSIFY_BY_FILE=false
RAG_DIVERSIFY_CANDIDATE_MULTIPLIER=3
RAG_QUERY_ROUTING=false
RAG_CROSS_DOC_TOP_K=5
RAG_SECTION_PRIOR=0.10
RAG_DIVERSITY_SCORE_MARGIN=0.15
RAG_MAX_CHUNKS_PER_FILE=2
RAG_PARENT_CONTEXT=false
RAG_PARENT_CONTEXT_MAX_CHARS=2400
RAG_PARENT_CONTEXT_MAX_TOKENS=3000
RAG_CHUNK_STRATEGY=legacy
RAG_INCLUDE_SECTION_PREFIX=false
ENHANCED_COLLECTION_NAME=biz_enhanced

LLM_TEMPERATURE=0.0
LLM_CHAT_TEMPERATURE=0.7
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_FALLBACK_MODEL=qwen-plus

EVAL_JUDGE_MODEL=qwen3.5-plus
EVAL_JUDGE_TEMPERATURE=0.0
EVAL_JUDGE_API_BASE=
EVAL_JUDGE_API_KEY=
EVAL_JUDGE_CACHE_PATH=reports/judge_cache.sqlite

CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

REDIS_URL=redis://redis:6379

CONTEXT_MAX_TOKENS=8000
CONTEXT_TRIMMING_STRATEGY=token_count
