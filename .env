# 应用配置
APP_NAME=OnCall Mind
DEBUG=True
HOST=0.0.0.0
PORT=9900

# DashScope 配置
DASHSCOPE_API_KEY=input your api key # 请输入DashScope API Key
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000
MILVUS_NPROBE=32

# RAG 配置
RAG_TOP_K=3
RAG_MODEL=qwen-max
RAG_MODE=basic

# Enhanced RAG 配置（RAG_MODE=enhanced 时生效）
QUERY_PREPROCESSOR_TYPE=none
RERANKER_TYPE=cross_encoder
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=3
RERANK_COARSE_TOP_K=10

# LLM 调用配置（P0-1.1: 统一管理 temperature/timeout/retries）
LLM_TEMPERATURE=0.0
LLM_CHAT_TEMPERATURE=0.7
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_FALLBACK_MODEL=qwen-plus

# 文档分块配置
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# MCP 服务配置
# 支持的 transport 类型：stdio（本地进程）、streamable-http（HTTP 流）
# 也可以配置真实的cls mcp服务： https://cloud.tencent.com/developer/mcp/server/11710
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# Redis 配置（P1-2.3: 默认启用，Docker Compose 中包含 Redis 容器）
REDIS_URL=redis://localhost:6379

# 上下文裁剪配置
CONTEXT_MAX_TOKENS=8000
CONTEXT_TRIMMING_STRATEGY=token_count
